* Set when agent acknowledges via MCP */\n    48→  acknowledgedAt?: string\n    49→  /** Set when agent resolves via MCP */\n    50→  resolvedAt?: string\n    51→  resolvedBy?: string\n    52→  resolutionSummary?: string\n    53→  dismissReason?: string\n    54→}\n    55→\n    56→export type AnnotationCreateInput = Pick<\n    57→  Annotation,\n    58→  'selector' | 'elementDescription' | 'componentChain' | 'feedback'\n    59→> & Partial<Pick<Annotation, 'piniaStores' | 'route' | 'expected' | 'actual' | 'screenshot'>>\n    60→\n    61→// ─── Webhook Types ────────────────────────────────────────────────────────────\n    62→\n    63→export type WebhookEvent =\n    64→  | 'annotation.created'\n    65→  | 'annotation.updated'\n    66→  | 'annotation.acknowledged'\n    67→  | 'annotation.resolved'\n    68→  | 'annotation.dismissed'\n    69→  | 'annotation.batch_copied'\n    70→  | 'session.started'\n    71→  | 'session.ended'\n    72→\n    73→export interface WebhookPayload {\n    74→  event: WebhookEvent\n    75→  timestamp: string\n    76→  annotation?: Annotation\n    77→  meta: {\n    78→    appName?: string\n    79→    appVersion?: string\n    80→    sessionId: string\n    81→  }\n    82→}\n    83→\n    84→export interface WebhookConfig {\n    85→  url: string\n    86→  secret?: string\n    87→  events?: WebhookEvent[] // undefined = all events\n    88→}\n    89→\n    90→// ─── Plugin Config ────────────────────────────────────────────────────────────\n    91→\n    92→export interface VuePointOptions {\n    93→  /** Master enable/disable. Default: auto-disabled in production. */\n    94→  enabled?: boolean\n    95→  /**\n    96→   * Component names to exclude from the hierarchy chain.\n    97→   * Defaults to a built-in PrimeVue filter list.\n    98→   * Pass `false` to disable all filtering.\n    99→   * Pass an array to replace the default list entirely.\n   100→   */\n   101→  filterComponents?: string[] | false\n   102→  /** Keyboard shortcut to toggle toolbar. Default: 'ctrl+shift+a' */\n   103→  shortcut?: string\n   104→  /** Pinia integration — surfaces store IDs in annotations */\n   105→  pinia?: {\n   106→    enabled: boolean\n   107→    /** Pass the Pinia instance created by createPinia() */\n   108→    instance?: unknown\n   109→  }\n   110→  /** MCP server options */\n   111→  mcp?: {\n   112→    enabled: boolean\n   113→    port?: number\n   114→    /** Bearer token for auth. Recommended for shared staging environments. */\n   115→    authToken?: string\n   116→  }\n   117→  /** REST API options */\n   118→  api?: {\n   119→    enabled: boolean\n   120→    port?: number\n   121→    authToken?: string\n   122→    cors?: string[] // allowed origins\n   123→  }\n   124→  /** Outbound webhooks */\n   125→  webhooks?: WebhookConfig[]\n   126→  /** App metadata included in webhook payloads */\n   127→  appMeta?: {\n   128→    name?: string\n   129→    version?: string\n   130→  }\n   131→}\n   132→\n   133→// ─── Output / Markdown ───────────────────────────────────────────────────────\n   134→\n   135→export interface MarkdownOutputOptions {\n   136→  /** Include screenshot as base64 img tag (large — off by default) */\n   137→  includeScreenshot?: boolean\n   138→  /** Include prop keys listing */\n   139→  includeProps?: boolean\n   140→}\n   141→"}]},"parent_tool_use_id":null,"session_id":"d4d0f974-b620-4d0c-b2b4-900d9f160396","uuid":"a7f77582-912e-470c-b71f-5be3e12fbe63","tool_use_result":{"type":"text","file":{"filePath":"/Users/juergen/Downloads/VuePoint/types.ts","content":"// ─── Annotation Types ────────────────────────────────────────────────────────\n\nexport type AnnotationStatus = 'pending' | 'acknowledged' | 'resolved' | 'dismissed'\n\nexport interface VueComponentInfo {\n  /** Inferred name: __name (script setup) → name (defineComponent) → SFC filename */\n  name: string\n  /** Absolute path from project root, e.g. src/views/users/UserCard.vue */\n  file?: string\n  /** Estimated line range (best-effort from source maps if available) */\n  line?: number\n  /** Props snapshot — top-level keys only, values redacted for security */\n  propKeys?: string[]\n}\n\nexport interface AnnotationRect {\n  x: number\n  y: number\n  width: number\n  height: number\n  scrollX: number\n  scrollY: number\n}\n\nexport interface Annotation {\n  id: string\n  /** Unique CSS selector path to the annotated element */\n  selector: string\n  /** Human-readable element description (tag, text content, aria-label) */\n  elementDescription: string\n  /** Ordered component chain: App → Page → ... → LeafComponent */\n  componentChain: VueComponentInfo[]\n  /** Pinia store IDs the component accesses (opt-in) */\n  piniaStores?: string[]\n  /** Current Vue Router route path, if available */\n  route?: string\n  /** User-provided feedback text */\n  feedback: string\n  /** Optional structured fields */\n  expected?: string\n  actual?: string\n  /** Base64 PNG screenshot of the annotated area (opt-in, Phase 2) */\n  screenshot?: string\n  status: AnnotationStatus\n  createdAt: string\n  updatedAt: string\n  /** Set when agent acknowledges via MCP */\n  acknowledgedAt?: string\n  /** Set when agent resolves via MCP */\n  resolvedAt?: string\n  resolvedBy?: string\n  resolutionSummary?: string\n  dismissReason?: string\n}\n\nexport type AnnotationCreateInput = Pick<\n  Annotation,\n  'selector' | 'elementDescription' | 'componentChain' | 'feedback'\n> & Partial<Pick<Annotation, 'piniaStores' | 'route' | 'expected' | 'actual' | 'screenshot'>>\n\n// ─── Webhook Types ────────────────────────────────────────────────────────────\n\nexport type WebhookEvent =\n  | 'annotation.created'\n  | 'annotation.updated'\n  | 'annotation.acknowledged'\n  | 'annotation.resolved'\n  | 'annotation.dismissed'\n  | 'annotation.batch_copied'\n  | 'session.started'\n  | 'session.ended'\n\nexport interface WebhookPayload {\n  event: WebhookEvent\n  timestamp: string\n  annotation?: Annotation\n  meta: {\n    appName?: string\n    appVersion?: string\n    sessionId: string\n  }\n}\n\nexport interface WebhookConfig {\n  url: string\n  secret?: string\n  events?: WebhookEvent[] // undefined = all events\n}\n\n// ─── Plugin Config ────────────────────────────────────────────────────────────\n\nexport interface VuePointOptions {\n  /** Master enable/disable. Default: auto-disabled in production. */\n  enabled?: boolean\n  /**\n   * Component names to exclude from the hierarchy chain.\n   * Defaults to a built-in PrimeVue filter list.\n   * Pass `false` to disable all filtering.\n   * Pass an array to replace the default list entirely.\n   */\n  filterComponents?: string[] | false\n  /** Keyboard shortcut to toggle toolbar. Default: 'ctrl+shift+a' */\n  shortcut?: string\n  /** Pinia integration — surfaces store IDs in annotations */\n  pinia?: {\n    enabled: boolean\n    /** Pass the Pinia instance created by createPinia() */\n    instance?: unknown\n  }\n  /** MCP server options */\n  mcp?: {\n    enabled: boolean\n    port?: number\n    /** Bearer token for auth. Recommended for shared staging environments. */\n    authToken?: string\n  }\n  /** REST API options */\n  api?: {\n    enabled: boolean\n    port?: number\n    authToken?: string\n    cors?: string[] // allowed origins\n  }\n  /** Outbound webhooks */\n  webhooks?: WebhookConfig[]\n  /** App metadata included in webhook payloads */\n  appMeta?: {\n    name?: string\n    version?: string\n  }\n}\n\n// ─── Output / Markdown ───────────────────────────────────────────────────────\n\nexport interface MarkdownOutputOptions {\n  /** Include screenshot as base64 img tag (large — off by default) */\n  includeScreenshot?: boolean\n  /** Include prop keys listing */\n  includeProps?: boolean\n}\n","numLines":141,"startLine":1,"totalLines":141}}}
