{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014TXxRi6CC168zZDUU3Ssr8","type":"tool_result","content":"     1→/**\n     2→ * useAnnotations.ts\n     3→ *\n     4→ * Reactive store for annotation state. Intentionally not Pinia — VuePoint\n     5→ * manages its own isolated state to avoid polluting the host app's store.\n     6→ *\n     7→ * This composable is the single source of truth for all annotations in\n     8→ * the current session. The toolbar UI, MCP server, and REST API all read\n     9→ * from and write to this same reactive state via the plugin's provide/inject.\n    10→ */\n    11→\n    12→import { ref, computed, readonly } from 'vue'\n    13→import type { Annotation, AnnotationCreateInput } from '@vuepoint/core'\n    14→import { generateId, now } from '@vuepoint/core'\n    15→\n    16→export const VUEPOINT_ANNOTATIONS_KEY = Symbol('vuepoint:annotations')\n    17→\n    18→export function useAnnotationsStore() {\n    19→  const annotations = ref<Annotation[]>([])\n    20→\n    21→  // ─── Reads ────────────────────────────────────────────────────────────────\n    22→\n    23→  const pending = computed(() =>\n    24→    annotations.value.filter((a) => a.status === 'pending')\n    25→  )\n    26→\n    27→  const all = readonly(annotations)\n    28→\n    29→  function getById(id: string): Annotation | undefined {\n    30→    return annotations.value.find((a) => a.id === id)\n    31→  }\n    32→\n    33→  // ─── Writes ───────────────────────────────────────────────────────────────\n    34→\n    35→  function create(input: AnnotationCreateInput): Annotation {\n    36→    const ann: Annotation = {\n    37→      id: generateId(),\n    38→      status: 'pending',\n    39→      createdAt: now(),\n    40→      updatedAt: now(),\n    41→      ...input,\n    42→    }\n    43→    annotations.value.push(ann)\n    44→    return ann\n    45→  }\n    46→\n    47→  function update(id: string, patch: Partial<Annotation>): Annotation | null {\n    48→    const idx = annotations.value.findIndex((a) => a.id === id)\n    49→    if (idx === -1) return null\n    50→    annotations.value[idx] = { ...annotations.value[idx], ...patch, updatedAt: now() }\n    51→    return annotations.value[idx]\n    52→  }\n    53→\n    54→  function acknowledge(id: string): Annotation | null {\n    55→    return update(id, { status: 'acknowledged', acknowledgedAt: now() })\n    56→  }\n    57→\n    58→  function resolve(id: string, summary?: string, resolvedBy?: string): Annotation | null {\n    59→    return update(id, {\n    60→      status: 'resolved',\n    61→      resolvedAt: now(),\n    62→      resolvedBy,\n    63→      resolutionSummary: summary,\n    64→    })\n    65→  }\n    66→\n    67→  function dismiss(id: string, reason?: string): Annotation | null {\n    68→    return update(id, { status: 'dismissed', dismissReason: reason })\n    69→  }\n    70→\n    71→  function remove(id: string): boolean {\n    72→    const idx = annotations.value.findIndex((a) => a.id === id)\n    73→    if (idx === -1) return false\n    74→    annotations.value.splice(idx, 1)\n    75→    return true\n    76→  }\n    77→\n    78→  function clear(): void {\n    79→    annotations.value = []\n    80→  }\n    81→\n    82→  return {\n    83→    // state\n    84→    annotations: all,\n    85→    pending,\n    86→    // reads\n    87→    getById,\n    88→    // writes\n    89→    create,\n    90→    update,\n    91→    acknowledge,\n    92→    resolve,\n    93→    dismiss,\n    94→    remove,\n    95→    clear,\n    96→  }\n    97→}\n    98→\n    99→export type AnnotationsStore = ReturnType<typeof useAnnotationsStore>\n   100→"}]},"parent_tool_use_id":null,"session_id":"d4d0f974-b620-4d0c-b2b4-900d9f160396","uuid":"fcc867df-b42c-423f-b080-8d4f80600812","tool_use_result":{"type":"text","file":{"filePath":"/Users/juergen/Downloads/VuePoint/useAnnotations.ts","content":"/**\n * useAnnotations.ts\n *\n * Reactive store for annotation state. Intentionally not Pinia — VuePoint\n * manages its own isolated state to avoid polluting the host app's store.\n *\n * This composable is the single source of truth for all annotations in\n * the current session. The toolbar UI, MCP server, and REST API all read\n * from and write to this same reactive state via the plugin's provide/inject.\n */\n\nimport { ref, computed, readonly } from 'vue'\nimport type { Annotation, AnnotationCreateInput } from '@vuepoint/core'\nimport { generateId, now } from '@vuepoint/core'\n\nexport const VUEPOINT_ANNOTATIONS_KEY = Symbol('vuepoint:annotations')\n\nexport function useAnnotationsStore() {\n  const annotations = ref<Annotation[]>([])\n\n  // ─── Reads ────────────────────────────────────────────────────────────────\n\n  const pending = computed(() =>\n    annotations.value.filter((a) => a.status === 'pending')\n  )\n\n  const all = readonly(annotations)\n\n  function getById(id: string): Annotation | undefined {\n    return annotations.value.find((a) => a.id === id)\n  }\n\n  // ─── Writes ───────────────────────────────────────────────────────────────\n\n  function create(input: AnnotationCreateInput): Annotation {\n    const ann: Annotation = {\n      id: generateId(),\n      status: 'pending',\n      createdAt: now(),\n      updatedAt: now(),\n      ...input,\n    }\n    annotations.value.push(ann)\n    return ann\n  }\n\n  function update(id: string, patch: Partial<Annotation>): Annotation | null {\n    const idx = annotations.value.findIndex((a) => a.id === id)\n    if (idx === -1) return null\n    annotations.value[idx] = { ...annotations.value[idx], ...patch, updatedAt: now() }\n    return annotations.value[idx]\n  }\n\n  function acknowledge(id: string): Annotation | null {\n    return update(id, { status: 'acknowledged', acknowledgedAt: now() })\n  }\n\n  function resolve(id: string, summary?: string, resolvedBy?: string): Annotation | null {\n    return update(id, {\n      status: 'resolved',\n      resolvedAt: now(),\n      resolvedBy,\n      resolutionSummary: summary,\n    })\n  }\n\n  function dismiss(id: string, reason?: string): Annotation | null {\n    return update(id, { status: 'dismissed', dismissReason: reason })\n  }\n\n  function remove(id: string): boolean {\n    const idx = annotations.value.findIndex((a) => a.id === id)\n    if (idx === -1) return false\n    annotations.value.splice(idx, 1)\n    return true\n  }\n\n  function clear(): void {\n    annotations.value = []\n  }\n\n  return {\n    // state\n    annotations: all,\n    pending,\n    // reads\n    getById,\n    // writes\n    create,\n    update,\n    acknowledge,\n    resolve,\n    dismiss,\n    remove,\n    clear,\n  }\n}\n\nexport type AnnotationsStore = ReturnType<typeof useAnnotationsStore>\n","numLines":100,"startLine":1,"totalLines":100}}}
