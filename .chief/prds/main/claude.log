{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WVn8Cw6XLPB1KNaYVaj2Fn","type":"tool_result","content":"     1вҶ’export type {\n     2вҶ’  AnnotationStatus,\n     3вҶ’  VueComponentInfo,\n     4вҶ’  AnnotationRect,\n     5вҶ’  Annotation,\n     6вҶ’  AnnotationCreateInput,\n     7вҶ’  WebhookEvent,\n     8вҶ’  WebhookPayload,\n     9вҶ’  WebhookConfig,\n    10вҶ’  VuePointOptions,\n    11вҶ’  MarkdownOutputOptions,\n    12вҶ’} from './types.js'\n    13вҶ’\n    14вҶ’export { generateSelector, describeElement } from './selector.js'\n    15вҶ’export { formatAnnotation, formatAnnotationBatch, generateId, now } from './output.js'\n    16вҶ’export { PRIMEVUE_FILTER, VUE_BUILTINS, buildFilter } from './primevue-filter.js'\n    17вҶ’"}]},"parent_tool_use_id":"toolu_01GkQeUdN6pAEMLrrFTfMqiN","session_id":"d22e533d-f41a-4d26-96cc-a989c39cb512","uuid":"25341beb-3a08-4575-b5e1-f11e6961e397"}
