{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UtP5qLgzGKXRBubCLbibpf","type":"tool_result","content":"     1вҶ’/**\n     2вҶ’ * selector.ts\n     3вҶ’ *\n     4вҶ’ * Generates a unique, greppable CSS selector for a given DOM element.\n     5вҶ’ * Strategy (in order of preference):\n     6вҶ’ *   1. Unique ID\n     7вҶ’ *   2. Unique data-testid or data-cy attribute\n     8вҶ’ *   3. Class-based path (stopping at unique node)\n     9вҶ’ *   4. Nth-child fallback path\n    10вҶ’ */\n    11вҶ’\n    12вҶ’const MAX_DEPTH = 8\n    13вҶ’\n    14вҶ’/** Attributes we treat as stable anchors (in priority order) */\n    15вҶ’const ANCHOR_ATTRS = ['data-testid', 'data-cy', 'data-e2e', 'aria-label', 'name', 'role']\n    16вҶ’\n    17вҶ’function attrSelector(el: Element, attr: string): string | null {\n    18вҶ’  const val = el.getAttribute(attr)\n    19вҶ’  if (!val) return null\n    20вҶ’  // Sanitise: strip quotes, limit length\n    21вҶ’  const safe = val.replace(/\"/g, '').slice(0, 60)\n    22вҶ’  return `[${attr}=\"${safe}\"]`\n    23вҶ’}\n    24вҶ’\n    25вҶ’function classSelector(el: Element): string {\n    26вҶ’  // Filter out dynamic/generated classes (Tailwind JIT hashes, CSS modules, etc.)\n    27вҶ’  // Heuristic: skip classes that are longer than 30 chars or start with a digit\n    28вҶ’  const classes = Array.from(el.classList).filter(\n    29вҶ’    (c) => c.length <= 30 && !/^\\d/.test(c) && !/^[a-f0-9]{5,}$/.test(c)\n    30вҶ’  )\n    31вҶ’  return classes.length > 0 ? '.' + classes.join('.') : ''\n    32вҶ’}\n    33вҶ’\n    34вҶ’function nthChild(el: Element): string {\n    35вҶ’  const parent = el.parentElement\n    36вҶ’  if (!parent) return el.tagName.toLowerCase()\n    37вҶ’  const idx = Array.from(parent.children).indexOf(el) + 1\n    38вҶ’  return `${el.tagName.toLowerCase()}:nth-child(${idx})`\n    39вҶ’}\n    40вҶ’\n    41вҶ’function isUnique(selector: string, root: Document | Element = document): boolean {\n    42вҶ’  try {\n    43вҶ’    return root.querySelectorAll(selector).length === 1\n    44вҶ’  } catch {\n    45вҶ’    return false\n    46вҶ’  }\n    47вҶ’}\n    48вҶ’\n    49вҶ’function segmentFor(el: Element): string {\n    50вҶ’  // 1. Unique ID (skip auto-generated IDs like `:r0:`)\n    51вҶ’  if (el.id && !/^[:r]/.test(el.id) && isUnique(`#${CSS.escape(el.id)}`)) {\n    52вҶ’    return `#${CSS.escape(el.id)}`\n    53вҶ’  }\n    54вҶ’\n    55вҶ’  // 2. Anchor attributes\n    56вҶ’  for (const attr of ANCHOR_ATTRS) {\n    57вҶ’    const sel = attrSelector(el, attr)\n    58вҶ’    if (sel) return `${el.tagName.toLowerCase()}${sel}`\n    59вҶ’  }\n    60вҶ’\n    61вҶ’  // 3. Tag + classes\n    62вҶ’  const tag = el.tagName.toLowerCase()\n    63вҶ’  const cls = classSelector(el)\n    64вҶ’  if (cls) return `${tag}${cls}`\n    65вҶ’\n    66вҶ’  // 4. Nth-child fallback\n    67вҶ’  return nthChild(el)\n    68вҶ’}\n    69вҶ’\n    70вҶ’export function generateSelector(target: Element): string {\n    71вҶ’  const segments: string[] = []\n    72вҶ’  let el: Element | null = target\n    73вҶ’\n    74вҶ’  for (let depth = 0; el && depth < MAX_DEPTH; depth++) {\n    75вҶ’    const seg = segmentFor(el)\n    76вҶ’    segments.unshift(seg)\n    77вҶ’\n    78вҶ’    const candidate = segments.join(' > ')\n    79вҶ’    if (isUnique(candidate)) break\n    80вҶ’\n    81вҶ’    // If we hit a unique anchor (ID or data-testid), stop climbing\n    82вҶ’    if (seg.startsWith('#') || seg.includes('[data-')) break\n    83вҶ’\n    84вҶ’    el = el.parentElement\n    85вҶ’  }\n    86вҶ’\n    87вҶ’  return segments.join(' > ')\n    88вҶ’}\n    89вҶ’\n    90вҶ’/**\n    91вҶ’ * Returns a human-readable description of the element for display in the\n    92вҶ’ * annotation output вҖ” prefers visible text, falls back to aria/tag/type.\n    93вҶ’ */\n    94вҶ’export function describeElement(el: Element): string {\n    95вҶ’  const tag = el.tagName.toLowerCase()\n    96вҶ’\n    97вҶ’  // Text content (capped)\n    98вҶ’  const text = el.textContent?.trim().slice(0, 80)\n    99вҶ’  if (text) return `<${tag}> \"${text}\"`\n   100вҶ’\n   101вҶ’  // Aria label\n   102вҶ’  const aria = el.getAttribute('aria-label')\n   103вҶ’  if (aria) return `<${tag}> [${aria}]`\n   104вҶ’\n   105вҶ’  // Input type/placeholder\n   106вҶ’  if (tag === 'input') {\n   107вҶ’    const type = (el as HTMLInputElement).type || 'text'\n   108вҶ’    const placeholder = (el as HTMLInputElement).placeholder\n   109вҶ’    return placeholder ? `<input[${type}]> \"${placeholder}\"` : `<input[${type}]>`\n   110вҶ’  }\n   111вҶ’\n   112вҶ’  // Image alt\n   113вҶ’  if (tag === 'img') {\n   114вҶ’    const alt = (el as HTMLImageElement).alt\n   115вҶ’    return alt ? `<img> \"${alt}\"` : '<img>'\n   116вҶ’  }\n   117вҶ’\n   118вҶ’  return `<${tag}>`\n   119вҶ’}\n   120вҶ’"}]},"parent_tool_use_id":null,"session_id":"deecd6a4-6ba2-4ba0-969e-05600d11bf33","uuid":"7570821e-ae97-4d61-831c-5a648d009802","tool_use_result":{"type":"text","file":{"filePath":"/Users/juergen/Downloads/VuePoint/packages/core/src/selector.ts","content":"/**\n * selector.ts\n *\n * Generates a unique, greppable CSS selector for a given DOM element.\n * Strategy (in order of preference):\n *   1. Unique ID\n *   2. Unique data-testid or data-cy attribute\n *   3. Class-based path (stopping at unique node)\n *   4. Nth-child fallback path\n */\n\nconst MAX_DEPTH = 8\n\n/** Attributes we treat as stable anchors (in priority order) */\nconst ANCHOR_ATTRS = ['data-testid', 'data-cy', 'data-e2e', 'aria-label', 'name', 'role']\n\nfunction attrSelector(el: Element, attr: string): string | null {\n  const val = el.getAttribute(attr)\n  if (!val) return null\n  // Sanitise: strip quotes, limit length\n  const safe = val.replace(/\"/g, '').slice(0, 60)\n  return `[${attr}=\"${safe}\"]`\n}\n\nfunction classSelector(el: Element): string {\n  // Filter out dynamic/generated classes (Tailwind JIT hashes, CSS modules, etc.)\n  // Heuristic: skip classes that are longer than 30 chars or start with a digit\n  const classes = Array.from(el.classList).filter(\n    (c) => c.length <= 30 && !/^\\d/.test(c) && !/^[a-f0-9]{5,}$/.test(c)\n  )\n  return classes.length > 0 ? '.' + classes.join('.') : ''\n}\n\nfunction nthChild(el: Element): string {\n  const parent = el.parentElement\n  if (!parent) return el.tagName.toLowerCase()\n  const idx = Array.from(parent.children).indexOf(el) + 1\n  return `${el.tagName.toLowerCase()}:nth-child(${idx})`\n}\n\nfunction isUnique(selector: string, root: Document | Element = document): boolean {\n  try {\n    return root.querySelectorAll(selector).length === 1\n  } catch {\n    return false\n  }\n}\n\nfunction segmentFor(el: Element): string {\n  // 1. Unique ID (skip auto-generated IDs like `:r0:`)\n  if (el.id && !/^[:r]/.test(el.id) && isUnique(`#${CSS.escape(el.id)}`)) {\n    return `#${CSS.escape(el.id)}`\n  }\n\n  // 2. Anchor attributes\n  for (const attr of ANCHOR_ATTRS) {\n    const sel = attrSelector(el, attr)\n    if (sel) return `${el.tagName.toLowerCase()}${sel}`\n  }\n\n  // 3. Tag + classes\n  const tag = el.tagName.toLowerCase()\n  const cls = classSelector(el)\n  if (cls) return `${tag}${cls}`\n\n  // 4. Nth-child fallback\n  return nthChild(el)\n}\n\nexport function generateSelector(target: Element): string {\n  const segments: string[] = []\n  let el: Element | null = target\n\n  for (let depth = 0; el && depth < MAX_DEPTH; depth++) {\n    const seg = segmentFor(el)\n    segments.unshift(seg)\n\n    const candidate = segments.join(' > ')\n    if (isUnique(candidate)) break\n\n    // If we hit a unique anchor (ID or data-testid), stop climbing\n    if (seg.startsWith('#') || seg.includes('[data-')) break\n\n    el = el.parentElement\n  }\n\n  return segments.join(' > ')\n}\n\n/**\n * Returns a human-readable description of the element for display in the\n * annotation output вҖ” prefers visible text, falls back to aria/tag/type.\n */\nexport function describeElement(el: Element): string {\n  const tag = el.tagName.toLowerCase()\n\n  // Text content (capped)\n  const text = el.textContent?.trim().slice(0, 80)\n  if (text) return `<${tag}> \"${text}\"`\n\n  // Aria label\n  const aria = el.getAttribute('aria-label')\n  if (aria) return `<${tag}> [${aria}]`\n\n  // Input type/placeholder\n  if (tag === 'input') {\n    const type = (el as HTMLInputElement).type || 'text'\n    const placeholder = (el as HTMLInputElement).placeholder\n    return placeholder ? `<input[${type}]> \"${placeholder}\"` : `<input[${type}]>`\n  }\n\n  // Image alt\n  if (tag === 'img') {\n    const alt = (el as HTMLImageElement).alt\n    return alt ? `<img> \"${alt}\"` : '<img>'\n  }\n\n  return `<${tag}>`\n}\n","numLines":120,"startLine":1,"totalLines":120}}}
