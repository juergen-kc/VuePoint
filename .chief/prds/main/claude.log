{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FJVvxkCKa2ShSGkHLoVtg3","type":"tool_result","content":"     1→/**\n     2→ * selector.ts\n     3→ *\n     4→ * Generates a unique, greppable CSS selector for a given DOM element.\n     5→ * Strategy (in order of preference):\n     6→ *   1. Unique ID\n     7→ *   2. Unique data-testid or data-cy attribute\n     8→ *   3. Class-based path (stopping at unique node)\n     9→ *   4. Nth-child fallback path\n    10→ */\n    11→\n    12→const MAX_DEPTH = 8\n    13→\n    14→/** Attributes we treat as stable anchors (in priority order) */\n    15→const ANCHOR_ATTRS = ['data-testid', 'data-cy', 'data-e2e', 'aria-label', 'name', 'role']\n    16→\n    17→function attrSelector(el: Element, attr: string): string | null {\n    18→  const val = el.getAttribute(attr)\n    19→  if (!val) return null\n    20→  // Sanitise: strip quotes, limit length\n    21→  const safe = val.replace(/\"/g, '').slice(0, 60)\n    22→  return `[${attr}=\"${safe}\"]`\n    23→}\n    24→\n    25→function classSelector(el: Element): string {\n    26→  // Filter out dynamic/generated classes (Tailwind JIT hashes, CSS modules, etc.)\n    27→  // Heuristic: skip classes that are longer than 30 chars or start with a digit\n    28→  const classes = Array.from(el.classList).filter(\n    29→    (c) => c.length <= 30 && !/^\\d/.test(c) && !/^[a-f0-9]{5,}$/.test(c)\n    30→  )\n    31→  return classes.length > 0 ? '.' + classes.join('.') : ''\n    32→}\n    33→\n    34→function nthChild(el: Element): string {\n    35→  const parent = el.parentElement\n    36→  if (!parent) return el.tagName.toLowerCase()\n    37→  const idx = Array.from(parent.children).indexOf(el) + 1\n    38→  return `${el.tagName.toLowerCase()}:nth-child(${idx})`\n    39→}\n    40→\n    41→function isUnique(selector: string, root: Document | Element = document): boolean {\n    42→  try {\n    43→    return root.querySelectorAll(selector).length === 1\n    44→  } catch {\n    45→    return false\n    46→  }\n    47→}\n    48→\n    49→function segmentFor(el: Element): string {\n    50→  // 1. Unique ID (skip auto-generated IDs like `:r0:`)\n    51→  if (el.id && !/^[:r]/.test(el.id) && isUnique(`#${CSS.escape(el.id)}`)) {\n    52→    return `#${CSS.escape(el.id)}`\n    53→  }\n    54→\n    55→  // 2. Anchor attributes\n    56→  for (const attr of ANCHOR_ATTRS) {\n    57→    const sel = attrSelector(el, attr)\n    58→    if (sel) return `${el.tagName.toLowerCase()}${sel}`\n    59→  }\n    60→\n    61→  // 3. Tag + classes\n    62→  const tag = el.tagName.toLowerCase()\n    63→  const cls = classSelector(el)\n    64→  if (cls) return `${tag}${cls}`\n    65→\n    66→  // 4. Nth-child fallback\n    67→  return nthChild(el)\n    68→}\n    69→\n    70→export function generateSelector(target: Element): string {\n    71→  const segments: string[] = []\n    72→  let el: Element | null = target\n    73→\n    74→  for (let depth = 0; el && depth < MAX_DEPTH; depth++) {\n    75→    const seg = segmentFor(el)\n    76→    segments.unshift(seg)\n    77→\n    78→    const candidate = segments.join(' > ')\n    79→    if (isUnique(candidate)) break\n    80→\n    81→    // If we hit a unique anchor (ID or data-testid), stop climbing\n    82→    if (seg.startsWith('#') || seg.includes('[data-')) break\n    83→\n    84→    el = el.parentElement\n    85→  }\n    86→\n    87→  return segments.join(' > ')\n    88→}\n    89→\n    90→/**\n    91→ * Returns a human-readable description of the element for display in the\n    92→ * annotation output — prefers visible text, falls back to aria/tag/type.\n    93→ */\n    94→export function describeElement(el: Element): string {\n    95→  const tag = el.tagName.toLowerCase()\n    96→\n    97→  // Text content (capped)\n    98→  const text = el.textContent?.trim().slice(0, 80)\n    99→  if (text) return `<${tag}> \"${text}\"`\n   100→\n   101→  // Aria label\n   102→  const aria = el.getAttribute('aria-label')\n   103→  if (aria) return `<${tag}> [${aria}]`\n   104→\n   105→  // Input type/placeholder\n   106→  if (tag === 'input') {\n   107→    const type = (el as HTMLInputElement).type || 'text'\n   108→    const placeholder = (el as HTMLInputElement).placeholder\n   109→    return placeholder ? `<input[${type}]> \"${placeholder}\"` : `<input[${type}]>`\n   110→  }\n   111→\n   112→  // Image alt\n   113→  if (tag === 'img') {\n   114→    const alt = (el as HTMLImageElement).alt\n   115→    return alt ? `<img> \"${alt}\"` : '<img>'\n   116→  }\n   117→\n   118→  return `<${tag}>`\n   119→}\n   120→"}]},"parent_tool_use_id":null,"session_id":"d4d0f974-b620-4d0c-b2b4-900d9f160396","uuid":"4efb364a-ab01-4447-919c-d30881543782","tool_use_result":{"type":"text","file":{"filePath":"/Users/juergen/Downloads/VuePoint/selector.ts","content":"/**\n * selector.ts\n *\n * Generates a unique, greppable CSS selector for a given DOM element.\n * Strategy (in order of preference):\n *   1. Unique ID\n *   2. Unique data-testid or data-cy attribute\n *   3. Class-based path (stopping at unique node)\n *   4. Nth-child fallback path\n */\n\nconst MAX_DEPTH = 8\n\n/** Attributes we treat as stable anchors (in priority order) */\nconst ANCHOR_ATTRS = ['data-testid', 'data-cy', 'data-e2e', 'aria-label', 'name', 'role']\n\nfunction attrSelector(el: Element, attr: string): string | null {\n  const val = el.getAttribute(attr)\n  if (!val) return null\n  // Sanitise: strip quotes, limit length\n  const safe = val.replace(/\"/g, '').slice(0, 60)\n  return `[${attr}=\"${safe}\"]`\n}\n\nfunction classSelector(el: Element): string {\n  // Filter out dynamic/generated classes (Tailwind JIT hashes, CSS modules, etc.)\n  // Heuristic: skip classes that are longer than 30 chars or start with a digit\n  const classes = Array.from(el.classList).filter(\n    (c) => c.length <= 30 && !/^\\d/.test(c) && !/^[a-f0-9]{5,}$/.test(c)\n  )\n  return classes.length > 0 ? '.' + classes.join('.') : ''\n}\n\nfunction nthChild(el: Element): string {\n  const parent = el.parentElement\n  if (!parent) return el.tagName.toLowerCase()\n  const idx = Array.from(parent.children).indexOf(el) + 1\n  return `${el.tagName.toLowerCase()}:nth-child(${idx})`\n}\n\nfunction isUnique(selector: string, root: Document | Element = document): boolean {\n  try {\n    return root.querySelectorAll(selector).length === 1\n  } catch {\n    return false\n  }\n}\n\nfunction segmentFor(el: Element): string {\n  // 1. Unique ID (skip auto-generated IDs like `:r0:`)\n  if (el.id && !/^[:r]/.test(el.id) && isUnique(`#${CSS.escape(el.id)}`)) {\n    return `#${CSS.escape(el.id)}`\n  }\n\n  // 2. Anchor attributes\n  for (const attr of ANCHOR_ATTRS) {\n    const sel = attrSelector(el, attr)\n    if (sel) return `${el.tagName.toLowerCase()}${sel}`\n  }\n\n  // 3. Tag + classes\n  const tag = el.tagName.toLowerCase()\n  const cls = classSelector(el)\n  if (cls) return `${tag}${cls}`\n\n  // 4. Nth-child fallback\n  return nthChild(el)\n}\n\nexport function generateSelector(target: Element): string {\n  const segments: string[] = []\n  let el: Element | null = target\n\n  for (let depth = 0; el && depth < MAX_DEPTH; depth++) {\n    const seg = segmentFor(el)\n    segments.unshift(seg)\n\n    const candidate = segments.join(' > ')\n    if (isUnique(candidate)) break\n\n    // If we hit a unique anchor (ID or data-testid), stop climbing\n    if (seg.startsWith('#') || seg.includes('[data-')) break\n\n    el = el.parentElement\n  }\n\n  return segments.join(' > ')\n}\n\n/**\n * Returns a human-readable description of the element for display in the\n * annotation output — prefers visible text, falls back to aria/tag/type.\n */\nexport function describeElement(el: Element): string {\n  const tag = el.tagName.toLowerCase()\n\n  // Text content (capped)\n  const text = el.textContent?.trim().slice(0, 80)\n  if (text) return `<${tag}> \"${text}\"`\n\n  // Aria label\n  const aria = el.getAttribute('aria-label')\n  if (aria) return `<${tag}> [${aria}]`\n\n  // Input type/placeholder\n  if (tag === 'input') {\n    const type = (el as HTMLInputElement).type || 'text'\n    const placeholder = (el as HTMLInputElement).placeholder\n    return placeholder ? `<input[${type}]> \"${placeholder}\"` : `<input[${type}]>`\n  }\n\n  // Image alt\n  if (tag === 'img') {\n    const alt = (el as HTMLImageElement).alt\n    return alt ? `<img> \"${alt}\"` : '<img>'\n  }\n\n  return `<${tag}>`\n}\n","numLines":120,"startLine":1,"totalLines":120}}}
