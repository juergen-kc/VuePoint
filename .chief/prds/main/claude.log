{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EEAXkUHDTbtL2VtyVUo9dc","type":"tool_result","content":"     1вҶ’/**\n     2вҶ’ * api.ts вҖ” VuePoint REST API + Webhook Bridge\n     3вҶ’ *\n     4вҶ’ * Serves two roles:\n     5вҶ’ *   1. REST API for external tooling / dashboards\n     6вҶ’ *   2. HTTP bridge between the browser SharedWorker and the stdio MCP server\n     7вҶ’ *\n     8вҶ’ * The browser plugin POSTs annotation updates here, and the MCP server\n     9вҶ’ * reads/writes via the same HTTP surface.\n    10вҶ’ *\n    11вҶ’ * Run: node packages/api/dist/api.js\n    12вҶ’ * Port: VUEPOINT_API_PORT (default 3742) for external REST\n    13вҶ’ *       VUEPOINT_BRIDGE_PORT (default 3741) for MCP bridge (same server, path-routed)\n    14вҶ’ */\n    15вҶ’\n    16вҶ’import Fastify from 'fastify'\n    17вҶ’import cors from '@fastify/cors'\n    18вҶ’import crypto from 'node:crypto'\n    19вҶ’import type {\n    20вҶ’  Annotation,\n    21вҶ’  WebhookConfig,\n    22вҶ’  WebhookEvent,\n    23вҶ’  WebhookPayload,\n    24вҶ’} from '@vuepoint/core'\n    25вҶ’import { generateId, now } from '@vuepoint/core'\n    26вҶ’\n    27вҶ’const PORT = Number(process.env.VUEPOINT_API_PORT ?? 3741)\n    28вҶ’const AUTH_TOKEN = process.env.VUEPOINT_AUTH_TOKEN\n    29вҶ’const CORS_ORIGINS = process.env.VUEPOINT_CORS?.split(',') ?? ['http://localhost:5173', 'http://localhost:3000']\n    30вҶ’\n    31вҶ’// Webhook configs loaded from env JSON or set via API\n    32вҶ’let webhooks: WebhookConfig[] = []\n    33вҶ’try {\n    34вҶ’  if (process.env.VUEPOINT_WEBHOOKS) {\n    35вҶ’    webhooks = JSON.parse(process.env.VUEPOINT_WEBHOOKS)\n    36вҶ’  }\n    37вҶ’} catch { /* no-op */ }\n    38вҶ’\n    39вҶ’// In-memory annotation store (shared between REST API and MCP bridge)\n    40вҶ’// In production this would be backed by SQLite or Redis for persistence\n    41вҶ’const annotationStore = new Map<string, Annotation>()\n    42вҶ’\n    43вҶ’const sessionId = generateId()\n    44вҶ’const appMeta = {\n    45вҶ’  name: process.env.VUEPOINT_APP_NAME,\n    46вҶ’  version: process.env.VUEPOINT_APP_VERSION,\n    47вҶ’}\n    48вҶ’\n    49вҶ’// в”Җв”Җв”Җ Server setup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    50вҶ’\n    51вҶ’const app = Fastify({ logger: false })\n    52вҶ’\n    53вҶ’await app.register(cors, {\n    54вҶ’  origin: CORS_ORIGINS,\n    55вҶ’  methods: ['GET', 'POST', 'PATCH', 'DELETE'],\n    56вҶ’})\n    57вҶ’\n    58вҶ’// Auth middleware\n    59вҶ’app.addHook('preHandler', async (req, reply) => {\n    60вҶ’  if (!AUTH_TOKEN) return // auth disabled\n    61вҶ’  if (req.url === '/health') return // health check always open\n    62вҶ’\n    63вҶ’  const header = req.headers.authorization\n    64вҶ’  if (!header?.startsWith('Bearer ') || header.slice(7) !== AUTH_TOKEN) {\n    65вҶ’    reply.status(401).send({ error: 'Unauthorized' })\n    66вҶ’  }\n    67вҶ’})\n    68вҶ’\n    69вҶ’// в”Җв”Җв”Җ Health в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    70вҶ’\n    71вҶ’app.get('/health', async () => ({\n    72вҶ’  status: 'ok',\n    73вҶ’  version: '0.1.0',\n    74вҶ’  annotations: annotationStore.size,\n    75вҶ’  sessionId,\n    76вҶ’}))\n    77вҶ’\n    78вҶ’// в”Җв”Җв”Җ Annotations CRUD в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    79вҶ’\n    80вҶ’app.get('/api/v1/annotations', async (req) => {\n    81вҶ’  const { status = 'pending' } = req.query as { status?: string }\n    82вҶ’  const all = Array.from(annotationStore.values())\n    83вҶ’  return status === 'all' ? all : all.filter((a) => a.status === status)\n    84вҶ’})\n    85вҶ’\n    86вҶ’app.get('/api/v1/annotations/export', async (req) => {\n    87вҶ’  const { format = 'json' } = req.query as { format?: 'json' | 'markdown' }\n    88вҶ’  const all = Array.from(annotationStore.values())\n    89вҶ’\n    90вҶ’  if (format === 'markdown') {\n    91вҶ’    const { formatAnnotationBatch } = await import('@vuepoint/core')\n    92вҶ’    return formatAnnotationBatch(all)\n    93вҶ’  }\n    94вҶ’\n    95вҶ’  return all\n    96вҶ’})\n    97вҶ’\n    98вҶ’app.get('/api/v1/annotations/:id', async (req, reply) => {\n    99вҶ’  const { id } = req.params as { id: string }\n   100вҶ’  const ann = annotationStore.get(id)\n   101вҶ’  if (!ann) return reply.status(404).send({ error: 'Not found' })\n   102вҶ’  return ann\n   103вҶ’})\n   104вҶ’\n   105вҶ’app.post('/api/v1/annotations', async (req, reply) => {\n   106вҶ’  const body = req.body as Partial<Annotation>\n   107вҶ’  if (!body.selector || !body.feedback) {\n   108вҶ’    return reply.status(400).send({ error: 'selector and feedback are required' })\n   109вҶ’  }\n   110вҶ’\n   111вҶ’  const ann: Annotation = {\n   112вҶ’    id: generateId(),\n   113вҶ’    status: 'pending',\n   114вҶ’    createdAt: now(),\n   115вҶ’    updatedAt: now(),\n   116вҶ’    selector: body.selector,\n   117вҶ’    elementDescription: body.elementDescription ?? body.selector,\n   118вҶ’    componentChain: body.componentChain ?? [],\n   119вҶ’    feedback: body.feedback,\n   120вҶ’    expected: body.expected,\n   121вҶ’    actual: body.actual,\n   122вҶ’    piniaStores: body.piniaStores,\n   123вҶ’    route: body.route,\n   124вҶ’  }\n   125вҶ’\n   126вҶ’  annotationStore.set(ann.id, ann)\n   127вҶ’  await fireWebhook('annotation.created', ann)\n   128вҶ’  return reply.status(201).send(ann)\n   129вҶ’})\n   130вҶ’\n   131вҶ’app.patch('/api/v1/annotations/:id', async (req, reply) => {\n   132вҶ’  const { id } = req.params as { id: string }\n   133вҶ’  const ann = annotationStore.get(id)\n   134вҶ’  if (!ann) return reply.status(404).send({ error: 'Not found' })\n   135вҶ’\n   136вҶ’  const patch = req.body as Partial<Annotation>\n   137вҶ’  const updated: Annotation = { ...ann, ...patch, updatedAt: now() }\n   138вҶ’\n   139вҶ’  if (patch.status === 'acknowledged' && !updated.acknowledgedAt) {\n   140вҶ’    updated.acknowledgedAt = now()\n   141вҶ’  }\n   142вҶ’  if (patch.status === 'resolved' && !updated.resolvedAt) {\n   143вҶ’    updated.resolvedAt = now()\n   144вҶ’  }\n   145вҶ’\n   146вҶ’  annotationStore.set(id, updated)\n   147вҶ’\n   148вҶ’  const eventMap: Partial<Record<string, WebhookEvent>> = {\n   149вҶ’    acknowledged: 'annotation.acknowledged',\n   150вҶ’    resolved: 'annotation.resolved',\n   151вҶ’    dismissed: 'annotation.dismissed',\n   152вҶ’  }\n   153вҶ’  const event = patch.status ? eventMap[patch.status] : 'annotation.updated'\n   154вҶ’  if (event) await fireWebhook(event, updated)\n   155вҶ’\n   156вҶ’  return updated\n   157вҶ’})\n   158вҶ’\n   159вҶ’app.delete('/api/v1/annotations/:id', async (req, reply) => {\n   160вҶ’  const { id } = req.params as { id: string }\n   161вҶ’  if (!annotationStore.has(id)) return reply.status(404).send({ error: 'Not found' })\n   162вҶ’  annotationStore.delete(id)\n   163вҶ’  reply.status(204).send()\n   164вҶ’})\n   165вҶ’\n   166вҶ’app.post('/api/v1/annotations/:id/ask', async (req, reply) => {\n   167вҶ’  const { id } = req.params as { id: string }\n   168вҶ’  const ann = annotationStore.get(id)\n   169вҶ’  if (!ann) return reply.status(404).send({ error: 'Not found' })\n   170вҶ’  const { question } = req.body as { question: string }\n   171вҶ’  // In Phase 2: push question to browser via WebSocket/SSE\n   172вҶ’  // For now: store as a note in the annotation\n   173вҶ’  const updated = { ...ann, agentQuestion: question, updatedAt: now() }\n   174вҶ’  annotationStore.set(id, updated as Annotation)\n   175вҶ’  return { status: 'question_sent', question }\n   176вҶ’})\n   177вҶ’\n   178вҶ’// в”Җв”Җв”Җ App context в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   179вҶ’\n   180вҶ’let appContext: Record<string, unknown> = {}\n   181вҶ’\n   182вҶ’app.get('/api/v1/context', async () => appContext)\n   183вҶ’\n   184вҶ’// Called by the browser plugin to sync current route/context\n   185вҶ’app.post('/api/v1/context', async (req) => {\n   186вҶ’  appContext = req.body as Record<string, unknown>\n   187вҶ’  return { ok: true }\n   188вҶ’})\n   189вҶ’\n   190вҶ’// в”Җв”Җв”Җ Component info в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   191вҶ’\n   192вҶ’app.get('/api/v1/component', async (req, reply) => {\n   193вҶ’  const { selector, name } = req.query as { selector?: string; name?: string }\n   194вҶ’  if (!selector && !name) {\n   195вҶ’    return reply.status(400).send({ error: 'selector or name required' })\n   196вҶ’  }\n   197вҶ’  // Proxy to browser via SSE/WS вҖ” for now return a stub\n   198вҶ’  // Phase 2: browser responds to an inspection request via WebSocket\n   199вҶ’  return {\n   200вҶ’    note: 'Component inspection requires a WebSocket connection to the browser. Available in Phase 2.',\n   201вҶ’    queried: { selector, name },\n   202вҶ’  }\n   203вҶ’})\n   204вҶ’\n   205вҶ’// в”Җв”Җв”Җ Webhook management в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   206вҶ’\n   207вҶ’app.get('/api/v1/webhooks', async () => webhooks.map((w) => ({ url: w.url, events: w.events })))\n   208вҶ’\n   209вҶ’app.post('/api/v1/webhooks/test', async (req) => {\n   210вҶ’  const { url } = req.body as { url?: string }\n   211вҶ’  const target = url ?? webhooks[0]?.url\n   212вҶ’  if (!target) return { error: 'No webhook configured' }\n   213вҶ’\n   214вҶ’  const testPayload: WebhookPayload = {\n   215вҶ’    event: 'session.started',\n   216вҶ’    timestamp: now(),\n   217вҶ’    meta: { sessionId, ...appMeta },\n   218вҶ’  }\n   219вҶ’  const delivered = await deliverWebhook(target, undefined, testPayload)\n   220вҶ’  return { delivered, url: target }\n   221вҶ’})\n   222вҶ’\n   223вҶ’// в”Җв”Җв”Җ Webhook engine в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   224вҶ’\n   225вҶ’async function fireWebhook(event: WebhookEvent, annotation?: Annotation): Promise<void> {\n   226вҶ’  const matching = webhooks.filter(\n   227вҶ’    (w) => !w.events || w.events.includes(event)\n   228вҶ’  )\n   229вҶ’  if (matching.length === 0) return\n   230вҶ’\n   231вҶ’  const payload: WebhookPayload = {\n   232вҶ’    event,\n   233вҶ’    timestamp: now(),\n   234вҶ’    annotation,\n   235вҶ’    meta: { sessionId, ...appMeta },\n   236вҶ’  }\n   237вҶ’\n   238вҶ’  await Promise.allSettled(\n   239вҶ’    matching.map((w) => deliverWebhookWithRetry(w.url, w.secret, payload))\n   240вҶ’  )\n   241вҶ’}\n   242вҶ’\n   243вҶ’async function deliverWebhookWithRetry(\n   244вҶ’  url: string,\n   245вҶ’  secret: string | undefined,\n   246вҶ’  payload: WebhookPayload,\n   247вҶ’  attempts = 3\n   248вҶ’): Promise<void> {\n   249вҶ’  for (let i = 0; i < attempts; i++) {\n   250вҶ’    const ok = await deliverWebhook(url, secret, payload)\n   251вҶ’    if (ok) return\n   252вҶ’    if (i < attempts - 1) {\n   253вҶ’      await sleep([1000, 5000, 30000][i])\n   254вҶ’    }\n   255вҶ’  }\n   256вҶ’  console.error(`[VuePoint] Webhook delivery failed after ${attempts} attempts: ${url}`)\n   257вҶ’}\n   258вҶ’\n   259вҶ’async function deliverWebhook(\n   260вҶ’  url: string,\n   261вҶ’  secret: string | undefined,\n   262вҶ’  payload: WebhookPayload\n   263вҶ’): Promise<boolean> {\n   264вҶ’  try {\n   265вҶ’    const body = JSON.stringify(payload)\n   266вҶ’    const headers: Record<string, string> = {\n   267вҶ’      'Content-Type': 'application/json',\n   268вҶ’      'User-Agent': 'VuePoint/0.1.0',\n   269вҶ’      'X-VuePoint-Event': payload.event,\n   270вҶ’    }\n   271вҶ’\n   272вҶ’    if (secret) {\n   273вҶ’      const sig = crypto\n   274вҶ’        .createHmac('sha256', secret)\n   275вҶ’        .update(body)\n   276вҶ’        .digest('hex')\n   277вҶ’      headers['X-VuePoint-Signature-256'] = `sha256=${sig}`\n   278вҶ’    }\n   279вҶ’\n   280вҶ’    const res = await fetch(url, { method: 'POST', headers, body })\n   281вҶ’    return res.ok\n   282вҶ’  } catch (err) {\n   283вҶ’    console.error(`[VuePoint] Webhook error:`, err)\n   284вҶ’    return false\n   285вҶ’  }\n   286вҶ’}\n   287вҶ’\n   288вҶ’function sleep(ms: number): Promise<void> {\n   289вҶ’  return new Promise((r) => setTimeout(r, ms))\n   290вҶ’}\n   291вҶ’\n   292вҶ’// в”Җв”Җв”Җ Start в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   293вҶ’\n   294вҶ’await app.listen({ port: PORT, host: '127.0.0.1' })\n   295вҶ’console.log(`[VuePoint API] Listening on http://127.0.0.1:${PORT}`)\n   296вҶ’"}]},"parent_tool_use_id":"toolu_01J7Ajq89jMfkkfzmzTeHcaX","session_id":"04004700-d8fd-4b80-9310-fd2da006cc99","uuid":"37667536-30ac-45cf-8158-fcaf663b8b76"}
