{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KFW4XP3BpeQdTYu8pMu8Bm","type":"tool_result","content":"     1→/**\n     2→ * api.ts — VuePoint REST API + Webhook Bridge\n     3→ *\n     4→ * Serves two roles:\n     5→ *   1. REST API for external tooling / dashboards\n     6→ *   2. HTTP bridge between the browser SharedWorker and the stdio MCP server\n     7→ *\n     8→ * The browser plugin POSTs annotation updates here, and the MCP server\n     9→ * reads/writes via the same HTTP surface.\n    10→ *\n    11→ * Run: node packages/api/dist/api.js\n    12→ * Port: VUEPOINT_API_PORT (default 3742) for external REST\n    13→ *       VUEPOINT_BRIDGE_PORT (default 3741) for MCP bridge (same server, path-routed)\n    14→ */\n    15→\n    16→import Fastify from 'fastify'\n    17→import cors from '@fastify/cors'\n    18→import crypto from 'node:crypto'\n    19→import type {\n    20→  Annotation,\n    21→  WebhookConfig,\n    22→  WebhookEvent,\n    23→  WebhookPayload,\n    24→} from '@vuepoint/core'\n    25→import { generateId, now } from '@vuepoint/core'\n    26→\n    27→const PORT = Number(process.env.VUEPOINT_API_PORT ?? 3741)\n    28→const AUTH_TOKEN = process.env.VUEPOINT_AUTH_TOKEN\n    29→const CORS_ORIGINS = process.env.VUEPOINT_CORS?.split(',') ?? ['http://localhost:5173', 'http://localhost:3000']\n    30→\n    31→// Webhook configs loaded from env JSON or set via API\n    32→let webhooks: WebhookConfig[] = []\n    33→try {\n    34→  if (process.env.VUEPOINT_WEBHOOKS) {\n    35→    webhooks = JSON.parse(process.env.VUEPOINT_WEBHOOKS)\n    36→  }\n    37→} catch { /* no-op */ }\n    38→\n    39→// In-memory annotation store (shared between REST API and MCP bridge)\n    40→// In production this would be backed by SQLite or Redis for persistence\n    41→const annotationStore = new Map<string, Annotation>()\n    42→\n    43→const sessionId = generateId()\n    44→const appMeta = {\n    45→  name: process.env.VUEPOINT_APP_NAME,\n    46→  version: process.env.VUEPOINT_APP_VERSION,\n    47→}\n    48→\n    49→// ─── Server setup ─────────────────────────────────────────────────────────────\n    50→\n    51→const app = Fastify({ logger: false })\n    52→\n    53→await app.register(cors, {\n    54→  origin: CORS_ORIGINS,\n    55→  methods: ['GET', 'POST', 'PATCH', 'DELETE'],\n    56→})\n    57→\n    58→// Auth middleware\n    59→app.addHook('preHandler', async (req, reply) => {\n    60→  if (!AUTH_TOKEN) return // auth disabled\n    61→  if (req.url === '/health') return // health check always open\n    62→\n    63→  const header = req.headers.authorization\n    64→  if (!header?.startsWith('Bearer ') || header.slice(7) !== AUTH_TOKEN) {\n    65→    reply.status(401).send({ error: 'Unauthorized' })\n    66→  }\n    67→})\n    68→\n    69→// ─── Health ───────────────────────────────────────────────────────────────────\n    70→\n    71→app.get('/health', async () => ({\n    72→  status: 'ok',\n    73→  version: '0.1.0',\n    74→  annotations: annotationStore.size,\n    75→  sessionId,\n    76→}))\n    77→\n    78→// ─── Annotations CRUD ─────────────────────────────────────────────────────────\n    79→\n    80→app.get('/api/v1/annotations', async (req) => {\n    81→  const { status = 'pending' } = req.query as { status?: string }\n    82→  const all = Array.from(annotationStore.values())\n    83→  return status === 'all' ? all : all.filter((a) => a.status === status)\n    84→})\n    85→\n    86→app.get('/api/v1/annotations/export', async (req) => {\n    87→  const { format = 'json' } = req.query as { format?: 'json' | 'markdown' }\n    88→  const all = Array.from(annotationStore.values())\n    89→\n    90→  if (format === 'markdown') {\n    91→    const { formatAnnotationBatch } = await import('@vuepoint/core')\n    92→    return formatAnnotationBatch(all)\n    93→  }\n    94→\n    95→  return all\n    96→})\n    97→\n    98→app.get('/api/v1/annotations/:id', async (req, reply) => {\n    99→  const { id } = req.params as { id: string }\n   100→  const ann = annotationStore.get(id)\n   101→  if (!ann) return reply.status(404).send({ error: 'Not found' })\n   102→  return ann\n   103→})\n   104→\n   105→app.post('/api/v1/annotations', async (req, reply) => {\n   106→  const body = req.body as Partial<Annotation>\n   107→  if (!body.selector || !body.feedback) {\n   108→    return reply.status(400).send({ error: 'selector and feedback are required' })\n   109→  }\n   110→\n   111→  const ann: Annotation = {\n   112→    id: generateId(),\n   113→    status: 'pending',\n   114→    createdAt: now(),\n   115→    updatedAt: now(),\n   116→    selector: body.selector,\n   117→    elementDescription: body.elementDescription ?? body.selector,\n   118→    componentChain: body.componentChain ?? [],\n   119→    feedback: body.feedback,\n   120→    expected: body.expected,\n   121→    actual: body.actual,\n   122→    piniaStores: body.piniaStores,\n   123→    route: body.route,\n   124→  }\n   125→\n   126→  annotationStore.set(ann.id, ann)\n   127→  await fireWebhook('annotation.created', ann)\n   128→  return reply.status(201).send(ann)\n   129→})\n   130→\n   131→app.patch('/api/v1/annotations/:id', async (req, reply) => {\n   132→  const { id } = req.params as { id: string }\n   133→  const ann = annotationStore.get(id)\n   134→  if (!ann) return reply.status(404).send({ error: 'Not found' })\n   135→\n   136→  const patch = req.body as Partial<Annotation>\n   137→  const updated: Annotation = { ...ann, ...patch, updatedAt: now() }\n   138→\n   139→  if (patch.status === 'acknowledged' && !updated.acknowledgedAt) {\n   140→    updated.acknowledgedAt = now()\n   141→  }\n   142→  if (patch.status === 'resolved' && !updated.resolvedAt) {\n   143→    updated.resolvedAt = now()\n   144→  }\n   145→\n   146→  annotationStore.set(id, updated)\n   147→\n   148→  const eventMap: Partial<Record<string, WebhookEvent>> = {\n   149→    acknowledged: 'annotation.acknowledged',\n   150→    resolved: 'annotation.resolved',\n   151→    dismissed: 'annotation.dismissed',\n   152→  }\n   153→  const event = patch.status ? eventMap[patch.status] : 'annotation.updated'\n   154→  if (event) await fireWebhook(event, updated)\n   155→\n   156→  return updated\n   157→})\n   158→\n   159→app.delete('/api/v1/annotations/:id', async (req, reply) => {\n   160→  const { id } = req.params as { id: string }\n   161→  if (!annotationStore.has(id)) return reply.status(404).send({ error: 'Not found' })\n   162→  annotationStore.delete(id)\n   163→  reply.status(204).send()\n   164→})\n   165→\n   166→app.post('/api/v1/annotations/:id/ask', async (req, reply) => {\n   167→  const { id } = req.params as { id: string }\n   168→  const ann = annotationStore.get(id)\n   169→  if (!ann) return reply.status(404).send({ error: 'Not found' })\n   170→  const { question } = req.body as { question: string }\n   171→  // In Phase 2: push question to browser via WebSocket/SSE\n   172→  // For now: store as a note in the annotation\n   173→  const updated = { ...ann, agentQuestion: question, updatedAt: now() }\n   174→  annotationStore.set(id, updated as Annotation)\n   175→  return { status: 'question_sent', question }\n   176→})\n   177→\n   178→// ─── App context ──────────────────────────────────────────────────────────────\n   179→\n   180→let appContext: Record<string, unknown> = {}\n   181→\n   182→app.get('/api/v1/context', async () => appContext)\n   183→\n   184→// Called by the browser plugin to sync current route/context\n   185→app.post('/api/v1/context', async (req) => {\n   186→  appContext = req.body as Record<string, unknown>\n   187→  return { ok: true }\n   188→})\n   189→\n   190→// ─── Component info ───────────────────────────────────────────────────────────\n   191→\n   192→app.get('/api/v1/component', async (req, reply) => {\n   193→  const { selector, name } = req.query as { selector?: string; name?: string }\n   194→  if (!selector && !name) {\n   195→    return reply.status(400).send({ error: 'selector or name required' })\n   196→  }\n   197→  // Proxy to browser via SSE/WS — for now return a stub\n   198→  // Phase 2: browser responds to an inspection request via WebSocket\n   199→  return {\n   200→    note: 'Component inspection requires a WebSocket connection to the browser. Available in Phase 2.',\n   201→    queried: { selector, name },\n   202→  }\n   203→})\n   204→\n   205→// ─── Webhook management ───────────────────────────────────────────────────────\n   206→\n   207→app.get('/api/v1/webhooks', async () => webhooks.map((w) => ({ url: w.url, events: w.events })))\n   208→\n   209→app.post('/api/v1/webhooks/test', async (req) => {\n   210→  const { url } = req.body as { url?: string }\n   211→  const target = url ?? webhooks[0]?.url\n   212→  if (!target) return { error: 'No webhook configured' }\n   213→\n   214→  const testPayload: WebhookPayload = {\n   215→    event: 'session.started',\n   216→    timestamp: now(),\n   217→    meta: { sessionId, ...appMeta },\n   218→  }\n   219→  const delivered = await deliverWebhook(target, undefined, testPayload)\n   220→  return { delivered, url: target }\n   221→})\n   222→\n   223→// ─── Webhook engine ───────────────────────────────────────────────────────────\n   224→\n   225→async function fireWebhook(event: WebhookEvent, annotation?: Annotation): Promise<void> {\n   226→  const matching = webhooks.filter(\n   227→    (w) => !w.events || w.events.includes(event)\n   228→  )\n   229→  if (matching.length === 0) return\n   230→\n   231→  const payload: WebhookPayload = {\n   232→    event,\n   233→    timestamp: now(),\n   234→    annotation,\n   235→    meta: { sessionId, ...appMeta },\n   236→  }\n   237→\n   238→  await Promise.allSettled(\n   239→    matching.map((w) => deliverWebhookWithRetry(w.url, w.secret, payload))\n   240→  )\n   241→}\n   242→\n   243→async function deliverWebhookWithRetry(\n   244→  url: string,\n   245→  secret: string | undefined,\n   246→  payload: WebhookPayload,\n   247→  attempts = 3\n   248→): Promise<void> {\n   249→  for (let i = 0; i < attempts; i++) {\n   250→    const ok = await deliverWebhook(url, secret, payload)\n   251→    if (ok) return\n   252→    if (i < attempts - 1) {\n   253→      await sleep([1000, 5000, 30000][i])\n   254→    }\n   255→  }\n   256→  console.error(`[VuePoint] Webhook delivery failed after ${attempts} attempts: ${url}`)\n   257→}\n   258→\n   259→async function deliverWebhook(\n   260→  url: string,\n   261→  secret: string | undefined,\n   262→  payload: WebhookPayload\n   263→): Promise<boolean> {\n   264→  try {\n   265→    const body = JSON.stringify(payload)\n   266→    const headers: Record<string, string> = {\n   267→      'Content-Type': 'application/json',\n   268→      'User-Agent': 'VuePoint/0.1.0',\n   269→      'X-VuePoint-Event': payload.event,\n   270→    }\n   271→\n   272→    if (secret) {\n   273→      const sig = crypto\n   274→        .createHmac('sha256', secret)\n   275→        .update(body)\n   276→        .digest('hex')\n   277→      headers['X-VuePoint-Signature-256'] = `sha256=${sig}`\n   278→    }\n   279→\n   280→    const res = await fetch(url, { method: 'POST', headers, body })\n   281→    return res.ok\n   282→  } catch (err) {\n   283→    console.error(`[VuePoint] Webhook error:`, err)\n   284→    return false\n   285→  }\n   286→}\n   287→\n   288→function sleep(ms: number): Promise<void> {\n   289→  return new Promise((r) => setTimeout(r, ms))\n   290→}\n   291→\n   292→// ─── Start ────────────────────────────────────────────────────────────────────\n   293→\n   294→await app.listen({ port: PORT, host: '127.0.0.1' })\n   295→console.log(`[VuePoint API] Listening on http://127.0.0.1:${PORT}`)\n   296→"}]},"parent_tool_use_id":null,"session_id":"d4d0f974-b620-4d0c-b2b4-900d9f160396","uuid":"32b69c22-1643-45bf-aa13-f829a733bd08","tool_use_result":{"type":"text","file":{"filePath":"/Users/juergen/Downloads/VuePoint/api.ts","content":"/**\n * api.ts — VuePoint REST API + Webhook Bridge\n *\n * Serves two roles:\n *   1. REST API for external tooling / dashboards\n *   2. HTTP bridge between the browser SharedWorker and the stdio MCP server\n *\n * The browser plugin POSTs annotation updates here, and the MCP server\n * reads/writes via the same HTTP surface.\n *\n * Run: node packages/api/dist/api.js\n * Port: VUEPOINT_API_PORT (default 3742) for external REST\n *       VUEPOINT_BRIDGE_PORT (default 3741) for MCP bridge (same server, path-routed)\n */\n\nimport Fastify from 'fastify'\nimport cors from '@fastify/cors'\nimport crypto from 'node:crypto'\nimport type {\n  Annotation,\n  WebhookConfig,\n  WebhookEvent,\n  WebhookPayload,\n} from '@vuepoint/core'\nimport { generateId, now } from '@vuepoint/core'\n\nconst PORT = Number(process.env.VUEPOINT_API_PORT ?? 3741)\nconst AUTH_TOKEN = process.env.VUEPOINT_AUTH_TOKEN\nconst CORS_ORIGINS = process.env.VUEPOINT_CORS?.split(',') ?? ['http://localhost:5173', 'http://localhost:3000']\n\n// Webhook configs loaded from env JSON or set via API\nlet webhooks: WebhookConfig[] = []\ntry {\n  if (process.env.VUEPOINT_WEBHOOKS) {\n    webhooks = JSON.parse(process.env.VUEPOINT_WEBHOOKS)\n  }\n} catch { /* no-op */ }\n\n// In-memory annotation store (shared between REST API and MCP bridge)\n// In production this would be backed by SQLite or Redis for persistence\nconst annotationStore = new Map<string, Annotation>()\n\nconst sessionId = generateId()\nconst appMeta = {\n  name: process.env.VUEPOINT_APP_NAME,\n  version: process.env.VUEPOINT_APP_VERSION,\n}\n\n// ─── Server setup ─────────────────────────────────────────────────────────────\n\nconst app = Fastify({ logger: false })\n\nawait app.register(cors, {\n  origin: CORS_ORIGINS,\n  methods: ['GET', 'POST', 'PATCH', 'DELETE'],\n})\n\n// Auth middleware\napp.addHook('preHandler', async (req, reply) => {\n  if (!AUTH_TOKEN) return // auth disabled\n  if (req.url === '/health') return // health check always open\n\n  const header = req.headers.authorization\n  if (!header?.startsWith('Bearer ') || header.slice(7) !== AUTH_TOKEN) {\n    reply.status(401).send({ error: 'Unauthorized' })\n  }\n})\n\n// ─── Health ───────────────────────────────────────────────────────────────────\n\napp.get('/health', async () => ({\n  status: 'ok',\n  version: '0.1.0',\n  annotations: annotationStore.size,\n  sessionId,\n}))\n\n// ─── Annotations CRUD ─────────────────────────────────────────────────────────\n\napp.get('/api/v1/annotations', async (req) => {\n  const { status = 'pending' } = req.query as { status?: string }\n  const all = Array.from(annotationStore.values())\n  return status === 'all' ? all : all.filter((a) => a.status === status)\n})\n\napp.get('/api/v1/annotations/export', async (req) => {\n  const { format = 'json' } = req.query as { format?: 'json' | 'markdown' }\n  const all = Array.from(annotationStore.values())\n\n  if (format === 'markdown') {\n    const { formatAnnotationBatch } = await import('@vuepoint/core')\n    return formatAnnotationBatch(all)\n  }\n\n  return all\n})\n\napp.get('/api/v1/annotations/:id', async (req, reply) => {\n  const { id } = req.params as { id: string }\n  const ann = annotationStore.get(id)\n  if (!ann) return reply.status(404).send({ error: 'Not found' })\n  return ann\n})\n\napp.post('/api/v1/annotations', async (req, reply) => {\n  const body = req.body as Partial<Annotation>\n  if (!body.selector || !body.feedback) {\n    return reply.status(400).send({ error: 'selector and feedback are required' })\n  }\n\n  const ann: Annotation = {\n    id: generateId(),\n    status: 'pending',\n    createdAt: now(),\n    updatedAt: now(),\n    selector: body.selector,\n    elementDescription: body.elementDescription ?? body.selector,\n    componentChain: body.componentChain ?? [],\n    feedback: body.feedback,\n    expected: body.expected,\n    actual: body.actual,\n    piniaStores: body.piniaStores,\n    route: body.route,\n  }\n\n  annotationStore.set(ann.id, ann)\n  await fireWebhook('annotation.created', ann)\n  return reply.status(201).send(ann)\n})\n\napp.patch('/api/v1/annotations/:id', async (req, reply) => {\n  const { id } = req.params as { id: string }\n  const ann = annotationStore.get(id)\n  if (!ann) return reply.status(404).send({ error: 'Not found' })\n\n  const patch = req.body as Partial<Annotation>\n  const updated: Annotation = { ...ann, ...patch, updatedAt: now() }\n\n  if (patch.status === 'acknowledged' && !updated.acknowledgedAt) {\n    updated.acknowledgedAt = now()\n  }\n  if (patch.status === 'resolved' && !updated.resolvedAt) {\n    updated.resolvedAt = now()\n  }\n\n  annotationStore.set(id, updated)\n\n  const eventMap: Partial<Record<string, WebhookEvent>> = {\n    acknowledged: 'annotation.acknowledged',\n    resolved: 'annotation.resolved',\n    dismissed: 'annotation.dismissed',\n  }\n  const event = patch.status ? eventMap[patch.status] : 'annotation.updated'\n  if (event) await fireWebhook(event, updated)\n\n  return updated\n})\n\napp.delete('/api/v1/annotations/:id', async (req, reply) => {\n  const { id } = req.params as { id: string }\n  if (!annotationStore.has(id)) return reply.status(404).send({ error: 'Not found' })\n  annotationStore.delete(id)\n  reply.status(204).send()\n})\n\napp.post('/api/v1/annotations/:id/ask', async (req, reply) => {\n  const { id } = req.params as { id: string }\n  const ann = annotationStore.get(id)\n  if (!ann) return reply.status(404).send({ error: 'Not found' })\n  const { question } = req.body as { question: string }\n  // In Phase 2: push question to browser via WebSocket/SSE\n  // For now: store as a note in the annotation\n  const updated = { ...ann, agentQuestion: question, updatedAt: now() }\n  annotationStore.set(id, updated as Annotation)\n  return { status: 'question_sent', question }\n})\n\n// ─── App context ──────────────────────────────────────────────────────────────\n\nlet appContext: Record<string, unknown> = {}\n\napp.get('/api/v1/context', async () => appContext)\n\n// Called by the browser plugin to sync current route/context\napp.post('/api/v1/context', async (req) => {\n  appContext = req.body as Record<string, unknown>\n  return { ok: true }\n})\n\n// ─── Component info ───────────────────────────────────────────────────────────\n\napp.get('/api/v1/component', async (req, reply) => {\n  const { selector, name } = req.query as { selector?: string; name?: string }\n  if (!selector && !name) {\n    return reply.status(400).send({ error: 'selector or name required' })\n  }\n  // Proxy to browser via SSE/WS — for now return a stub\n  // Phase 2: browser responds to an inspection request via WebSocket\n  return {\n    note: 'Component inspection requires a WebSocket connection to the browser. Available in Phase 2.',\n    queried: { selector, name },\n  }\n})\n\n// ─── Webhook management ───────────────────────────────────────────────────────\n\napp.get('/api/v1/webhooks', async () => webhooks.map((w) => ({ url: w.url, events: w.events })))\n\napp.post('/api/v1/webhooks/test', async (req) => {\n  const { url } = req.body as { url?: string }\n  const target = url ?? webhooks[0]?.url\n  if (!target) return { error: 'No webhook configured' }\n\n  const testPayload: WebhookPayload = {\n    event: 'session.started',\n    timestamp: now(),\n    meta: { sessionId, ...appMeta },\n  }\n  const delivered = await deliverWebhook(target, undefined, testPayload)\n  return { delivered, url: target }\n})\n\n// ─── Webhook engine ───────────────────────────────────────────────────────────\n\nasync function fireWebhook(event: WebhookEvent, annotation?: Annotation): Promise<void> {\n  const matching = webhooks.filter(\n    (w) => !w.events || w.events.includes(event)\n  )\n  if (matching.length === 0) return\n\n  const payload: WebhookPayload = {\n    event,\n    timestamp: now(),\n    annotation,\n    meta: { sessionId, ...appMeta },\n  }\n\n  await Promise.allSettled(\n    matching.map((w) => deliverWebhookWithRetry(w.url, w.secret, payload))\n  )\n}\n\nasync function deliverWebhookWithRetry(\n  url: string,\n  secret: string | undefined,\n  payload: WebhookPayload,\n  attempts = 3\n): Promise<void> {\n  for (let i = 0; i < attempts; i++) {\n    const ok = await deliverWebhook(url, secret, payload)\n    if (ok) return\n    if (i < attempts - 1) {\n      await sleep([1000, 5000, 30000][i])\n    }\n  }\n  console.error(`[VuePoint] Webhook delivery failed after ${attempts} attempts: ${url}`)\n}\n\nasync function deliverWebhook(\n  url: string,\n  secret: string | undefined,\n  payload: WebhookPayload\n): Promise<boolean> {\n  try {\n    const body = JSON.stringify(payload)\n    const headers: Record<string, string> = {\n      'Content-Type': 'application/json',\n      'User-Agent': 'VuePoint/0.1.0',\n      'X-VuePoint-Event': payload.event,\n    }\n\n    if (secret) {\n      const sig = crypto\n        .createHmac('sha256', secret)\n        .update(body)\n        .digest('hex')\n      headers['X-VuePoint-Signature-256'] = `sha256=${sig}`\n    }\n\n    const res = await fetch(url, { method: 'POST', headers, body })\n    return res.ok\n  } catch (err) {\n    console.error(`[VuePoint] Webhook error:`, err)\n    return false\n  }\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((r) => setTimeout(r, ms))\n}\n\n// ─── Start ────────────────────────────────────────────────────────────────────\n\nawait app.listen({ port: PORT, host: '127.0.0.1' })\nconsole.log(`[VuePoint API] Listening on http://127.0.0.1:${PORT}`)\n","numLines":296,"startLine":1,"totalLines":296}}}
