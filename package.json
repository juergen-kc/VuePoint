{
  "name": "vuepoint-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' run build",
    "typecheck": "tsc --noEmit",
    "dev": "pnpm --filter vuepoint-playground run dev",
    "dev:dashboard": "pnpm --filter vuepoint-dashboard run dev",
    "lint": "eslint 'packages/*/src/**/*.{ts,vue}' 'playground/src/**/*.{ts,vue}'",
    "test": "vitest run",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
