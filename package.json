{
  "name": "vuepoint-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' run build",
    "typecheck": "tsc --noEmit",
    "dev": "pnpm --filter vuepoint-playground run dev"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.0"
  }
}
