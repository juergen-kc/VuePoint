{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.d.ts",
    "packages/*/src/**/*.vue",
    "playground/src/**/*.ts",
    "playground/src/**/*.d.ts",
    "playground/src/**/*.vue"
  ],
  "exclude": [
    "packages/nuxt/src/runtime/**",
    "packages/extension/**"
  ]
}
